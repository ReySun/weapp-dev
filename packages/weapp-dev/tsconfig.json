{
  "compilerOptions": {
    // "baseUrl": ".",
    "types": ["miniprogram-api-typings"],
    "target": "es2022",
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "module": "es2022",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["./src/**/*"]
}
