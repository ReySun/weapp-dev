{
  "name": "weapp-dev",
  "version": "0.0.5",
  "description": "小程序原生开发增强工具",
  "keywords": [
    "miniprogram",
    "rolldown",
    "tsdown",
    "vite",
    "weapp",
    "weapp-dev",
    "原生微信小程序"
  ],
  "license": "MIT",
  "author": "ReySun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RangerPixel/weapp-dev.git",
    "directory": "packages/weapp-dev"
  },
  "bin": {
    "wd": "bin/weapp-dev.js",
    "weapp-dev": "bin/weapp-dev.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./config": {
      "import": {
        "types": "./dist/config.d.mts",
        "default": "./dist/config.mjs"
      },
      "require": {
        "types": "./dist/config.d.cts",
        "default": "./dist/config.cjs"
      }
    },
    "./cli": {
      "import": {
        "types": "./dist/cli.d.mts",
        "default": "./dist/cli.mjs"
      },
      "require": {
        "types": "./dist/cli.d.cts",
        "default": "./dist/cli.cjs"
      }
    },
    "./lodashFix": {
      "import": {
        "types": "./dist/lodashFix.d.mts",
        "default": "./dist/lodashFix.mjs"
      },
      "require": {
        "types": "./dist/lodashFix.d.cts",
        "default": "./dist/lodashFix.cjs"
      }
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown"
  },
  "dependencies": {
    "@weapp-core/escape": "^7.0.0",
    "cac": "^6.7.14",
    "consola": "^3.4.2",
    "listr2": "^10.2.1",
    "lodash-es": "catalog:",
    "miniprogram-ci": "catalog:",
    "node-html-parser": "^7.1.0",
    "ora": "^9.3.0",
    "postcss-selector-parser": "^7.1.1",
    "terminate": "^2.8.0",
    "tinyglobby": "^0.2.16",
    "tsdown": "catalog:",
    "vite": "catalog:",
    "weapp-tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@types/lodash-es": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "@weapp-dev/miniprogram-json-schema": "workspace:*",
    "miniprogram-api-typings": "catalog:",
    "publint": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.24.0"
}
