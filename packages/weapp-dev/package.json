{
  "name": "weapp-dev",
  "version": "1.0.0",
  "description": "小程序原生开发增强工具",
  "keywords": [
    "miniprogram",
    "rolldown",
    "tsdown",
    "vite",
    "weapp",
    "weapp-dev",
    "原生小程序",
    "微信/支付宝/头条小程序"
  ],
  "license": "MIT",
  "author": "ReySun",
  "bin": {
    "wd": "bin/weapp-dev.js",
    "weapp-dev": "bin/weapp-dev.js"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "./index": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "import": "./dist/config.mjs",
      "require": "./dist/config.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.mts",
      "import": "./dist/cli.mjs",
      "require": "./dist/cli.mjs"
    },
    "./lodashFix": {
      "types": "./dist/lodashFix.d.mts",
      "import": "./dist/lodashFix.mjs",
      "require": "./dist/lodashFix.mjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown"
  },
  "dependencies": {
    "@weapp-core/escape": "^7.0.0",
    "fast-glob": "catalog:",
    "listr2": "^10.2.1",
    "lodash-es": "catalog:",
    "miniprogram-ci": "catalog:",
    "node-html-parser": "^7.1.0",
    "ora": "^9.3.0",
    "postcss-selector-parser": "^7.1.1",
    "terminate": "^2.8.0",
    "tinyglobby": "^0.2.16",
    "tsdown": "catalog:",
    "vite": "catalog:"
  },
  "devDependencies": {
    "@types/lodash-es": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260417.1",
    "@weapp-dev/miniprogram-json-schema": "workspace:*",
    "miniprogram-api-typings": "catalog:"
  },
  "packageManager": "pnpm@10.24.0"
}
