{
  "name": "@weapp-dev/miniprogram-json-schema",
  "version": "1.0.2",
  "description": "微信小程序 JSON Schema 配置, JSON Schema 转 TS",
  "keywords": [
    "json-schema",
    "miniprogram",
    "miniprogram-json-schema",
    "miniprogram-json-schema to ts",
    "weapp",
    "weapp-dev"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/RangerPixel/weapp-dev.git",
    "directory": "packages/miniprogram-json-schema"
  },
  "files": [
    "src",
    "dist",
    ".vscode"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
   ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./schema/weapp/*": "./dist/schema/weapp/*",
    "./settings.json": "./.vscode/settings.json"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "weappJsonToTs": "tsx scripts/weappJsonToTs.ts"
  },
  "devDependencies": {
    "json-schema-to-typescript-lite": "^15.0.0",
    "publint": "catalog:",
    "tsx": "^4.21.0"
  },
  "packageManager": "pnpm@10.24.0"
}
